generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum InterviewStatus {
  IN_PROGRESS
  COMPLETED
}

model User {
  id        Int       @id @default(autoincrement())
  clerkId   String?   @unique @map("clerk_id")
  name      String
  email     String    @unique
  password  String?
  authProvider String @default("clerk") @map("auth_provider")
  createdAt DateTime  @default(now()) @map("created_at")
  deletedAt DateTime? @map("deleted_at")
  bannedUntil DateTime? @map("banned_until")
  banReason String? @map("ban_reason") @db.Text

  interviews Interview[]

  @@map("users")
}

model Interview {
  id         Int            @id @default(autoincrement())
  userId     Int            @map("user_id")
  role       String
  experience String
  personality String        @default("Senior Engineering Manager")
  techStack  Json           @map("tech_stack")
  status     InterviewStatus @default(IN_PROGRESS)
  warningCount Int          @default(0) @map("warning_count")
  followUpCount Int         @default(0) @map("follow_up_count")
  createdAt  DateTime       @default(now()) @map("created_at")
  completedAt DateTime?     @map("completed_at")

  user       User           @relation(fields: [userId], references: [id])
  questions  Question[]
  result     Result?

  @@index([userId])
  @@map("interviews")
}

model Question {
  id          Int       @id @default(autoincrement())
  interviewId Int       @map("interview_id")
  questionText String   @map("question_text")
  questionType String   @default("theory") @map("question_type")
  expectedAnswer String? @map("expected_answer") @db.Text
  keyConcepts Json?     @map("key_concepts")
  difficulty  String?
  topic       String?
  skill       String?
  language    String?
  starterCode String?   @map("starter_code") @db.Text
  testCases   Json?     @map("test_cases")
  hiddenTestCases Json? @map("hidden_test_cases")
  constraints Json?     @map("constraints_json")
  expectedOutput String? @map("expected_output") @db.Text
  evaluationType String? @map("evaluation_type")
  options     Json?     @map("options_json")
  correctOption String? @map("correct_option")
  explanation String?   @db.Text
  expectedTimeComplexity String? @map("expected_time_complexity")
  expectedSpaceComplexity String? @map("expected_space_complexity")
  createdAt   DateTime  @default(now()) @map("created_at")

  interview   Interview @relation(fields: [interviewId], references: [id])
  answers     Answer[]

  @@index([interviewId])
  @@map("questions")
}

model Answer {
  id         Int      @id @default(autoincrement())
  questionId Int      @map("question_id")
  answerText String   @map("answer_text")
  followUpQuestion String? @map("follow_up_question") @db.Text
  followUpAnswer String? @map("follow_up_answer") @db.Text
  followUpReason String? @map("follow_up_reason") @db.VarChar(500)
  interviewerReaction String? @map("interviewer_reaction") @db.VarChar(500)
  timeTakenSeconds Int? @map("time_taken_seconds")
  followUpTimeTakenSeconds Int? @map("follow_up_time_taken_seconds")
  code       String?  @db.Text
  score      Int?
  technicalAccuracy Int? @map("technical_accuracy")
  conceptCoverage Int? @map("concept_coverage")
  communicationScore Int? @map("communication_score")
  semanticSimilarity Int? @map("semantic_similarity")
  finalScore Int? @map("final_score")
  mainAnswerScore Int? @map("main_answer_score")
  followUpScore Int? @map("follow_up_score")
  matchedConcepts Json? @map("matched_concepts")
  missingConcepts Json? @map("missing_concepts")
  factorScores Json? @map("factor_scores")
  rating     String?
  language   String?
  audioFilePath String? @map("audio_file_path") @db.VarChar(1024)
  audioStatus String? @map("audio_status")
  audioDeletedAt DateTime? @map("audio_deleted_at")
  transcript String? @db.Text
  rawTranscript String? @map("raw_transcript") @db.Text
  correctedTranscript String? @map("corrected_transcript") @db.Text
  nlpScore Int? @map("nlp_score")
  answerLength Int? @map("answer_length")
  nlpMissingConcepts Json? @map("nlp_missing_concepts")
  fillerWordsCount Int? @default(0) @map("filler_words_count")
  fluencyScore Int? @map("fluency_score")
  clarityScore Int? @map("clarity_score")
  nlpSummary String? @map("nlp_summary") @db.Text
  aiScore Int? @map("ai_score")
  confidenceScore Int? @map("confidence_score")
  confidenceLevel String? @map("confidence_level")
  confidenceReasons Json? @map("confidence_reasons")
  confidenceTips Json? @map("confidence_tips")
  feedback   String?  @db.Text
  strengths  String?  @db.Text
  weaknesses String?  @db.Text
  suggestions String? @db.Text
  createdAt  DateTime @default(now()) @map("created_at")

  question   Question @relation(fields: [questionId], references: [id])

  @@index([questionId])
  @@map("answers")
}

model Result {
  id           Int      @id @default(autoincrement())
  interviewId  Int      @unique @map("interview_id")
  overallScore Int      @map("overall_score")
  summary      String   @db.Text
  questionWiseResults Json? @map("question_wise_results")
  recommendedFocusAreas Json? @map("recommended_focus_areas")
  createdAt    DateTime @default(now()) @map("created_at")

  interview Interview @relation(fields: [interviewId], references: [id])

  @@map("results")
}
